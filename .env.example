# ==========================================
# A 股极简智能分析器 配置说明
# ==========================================

# --- 选股与分析设置 ---
# 您要分析的 A 股代码列表 (逗号分隔，支持带后缀或不带后缀，如 sh600519/600519)
STOCK_LIST="600519,000001,sz002594"

# --- 模型平台选择 ---
# 支持 openai, deepseek, anthropic, gemini 四种写法
LLM_PROVIDER="deepseek"

# --- OpenAI / DeepSeek 配置 ---
OPENAI_API_KEY="sk-xxxx"
OPENAI_BASE_URL="https://api.deepseek.com/v1"
OPENAI_MODEL="deepseek-chat"

# --- Anthropic (Claude) 配置 ---
ANTHROPIC_API_KEY="sk-ant-xxxx"
ANTHROPIC_MODEL="claude-3-5-sonnet-20241022"

# --- Google Gemini 配置 ---
GEMINI_API_KEY="AIzaSy-xxxx"
GEMINI_MODEL="gemini-1.5-pro"

# --- 飞书机器人通知配置 ---
FEISHU_WEBHOOK_URL="https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxxxx"
