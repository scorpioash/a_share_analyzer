# --- A-Share Analyzer 环境变量模板 ---

# LLM 供应商配置 (custom, openai, deepseek 等)
AI_PROVIDER=custom
AI_API_KEY=your_api_key_here
AI_BASE_URL=https://api.your-provider.com/v1
AI_MODEL=claude-opus-4.7

# 网络配置 (auto, bypass, keep, use)
AK_NET_MODE=keep
# 是否开启 DNS 劫持绕过 (1 为开启, 0 为关闭)
AK_DNS_HIJACK=1

# 通达信配置 (可选)
TDX_HOST=119.147.212.81
TDX_PORT=7709

# 调试模式
DEBUG=0
